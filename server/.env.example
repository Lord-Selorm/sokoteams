# SMTP Configuration
# Create a copy of this file named .env and fill in your SMTP credentials

# Gmail example (requires App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password

# Outlook / Office 365 example
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=you@outlook.com
# SMTP_PASS=your-password

# Generic SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# From name/email shown in recipients' inbox
FROM_NAME=SokoTeams
FROM_EMAIL=noreply@sokoteams.com

# Server port
PORT=3005

# JWT secret (CHANGE THIS in production!)
JWT_SECRET=teamflow-dev-secret-change-in-production

# CORS allowed origins (comma-separated)
# In production, set to your domain: https://yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
